{%- from '_macros.jinja' import cmd with context -%}
{
  "permissions": {
    "allow": [
      {% if task_runner == 'make' -%}
      "Bash(make:*)",
      {% elif task_runner == 'just' -%}
      "Bash(just:*)",
      {% elif task_runner == 'none' -%}
      {{ ('Bash(' ~ verify_command ~ ')') | tojson }},
      {{ ('Bash(' ~ test_command ~ ')') | tojson }},
      {{ ('Bash(' ~ lint_command ~ ')') | tojson }},
      {{ ('Bash(' ~ fmt_command ~ ')') | tojson }},
      {% endif -%}
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard origin:*)",
      "Bash(rm -rf:*)"
    ]
  }{% if include_claude_hooks %},
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "test -x scripts/fmt-file.sh && scripts/fmt-file.sh \"$CLAUDE_TOOL_INPUT_FILE_PATH\" || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'rm -rf|push --force|reset --hard|DROP TABLE' && exit 2 || exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": {{ ("INPUT=$(cat); [ \"$(printf '%s' \"$INPUT\" | jq -r '.stop_hook_active // false')\" = 'true' ] && exit 0; " ~ cmd('verify') ~ " || exit 2") | tojson }}
          }
        ]
      }
    ]
  }{% endif %}
}
